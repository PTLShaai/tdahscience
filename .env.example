# ─────────────────────────────────────────
# TDAH Science — Variables d'environnement
# Copier en .env et remplir les valeurs
# ─────────────────────────────────────────

# Serveur
PORT=3020
NODE_ENV=production

# Base de données PostgreSQL
# Créer l'utilisateur dédié d'abord : sudo -u postgres bash setup_db.sh
DATABASE_URL=postgresql://tdahscience_user:MOT_DE_PASSE@localhost:5432/tdahscience

# Authentification JWT
JWT_SECRET=changez-moi-en-production-cle-longue-et-aleatoire

# Stockage des PDFs
UPLOADS_DIR=/var/www/tdahscience/uploads

# ─── IA Primaire (Anthropic Claude) ───────
AI_PRIMARY_PROVIDER=anthropic
AI_PRIMARY_MODEL=claude-sonnet-4-20250514
AI_PRIMARY_KEY=sk-ant-...

# ─── IA Secondaire (Infomaniak) ───────────
# Changer le modèle librement sans toucher au code
AI_SECONDARY_PROVIDER=infomaniak
AI_SECONDARY_MODEL=llama-3.3-70b
AI_SECONDARY_BASE_URL=https://api.infomaniak.com/1/ai/...
AI_SECONDARY_KEY=ik-...
